# Через прокси Vite (localhost:3000) — запросы идут на тот же хост, /api проксируется на бэкенд
VITE_API_URL=/api

# Либо напрямую на Laravel (нужен CORS)
# VITE_API_URL=http://localhost:8001/api

VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Опционально: цель прокси при npm run dev
# VITE_PROXY_TARGET=http://localhost:8001
